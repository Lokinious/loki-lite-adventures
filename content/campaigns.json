        "npcs": [
          {
            "id": "father_alden",
            "name": "Father Alden",
            "role": "priest",
            "personality": "Patient, solemn, and desperate for help.",
            "publicDescription": "A tired priest clutching a worn holy symbol.",
            "privateNotes": "He fears Brother Malrec caused the disappearances but does not want to accuse him without proof.",
            "dialoguePrompt": "Pilgrims have vanished along the old road. I beg you, find what remains of them.",
            "questHooks": "A missing pilgrims case, a road blessing, and a warning about crypt rites.",
            "linkedEntityId": "father_alden_entity"
          },
          {
            "id": "marta_the_merchant",
            "name": "Marta the Merchant",
            "role": "merchant",
            "personality": "Warm, practical, and suspicious of the weather.",
            "publicDescription": "A merchant arranging travel goods at Wayfarer Supplies.",
            "privateNotes": "Knows the roads well and has noticed strange pilgrims leaving after dark.",
            "dialoguePrompt": "Ask about the Faithful Road, supplies, or the old shrine.",
            "questHooks": "Can direct the party to useful travel gear and local gossip.",
            "linkedEntityId": "marta_entity"
          },
          {
            "id": "brother_tomas",
            "name": "Brother Tomas",
            "role": "wounded survivor",
            "personality": "Frantic, exhausted, and honest.",
            "publicDescription": "A wounded monk barely clinging to life.",
            "privateNotes": "He saw Brother Malrec performing rites in the crypt.",
            "dialoguePrompt": "The dead came from Saint Aric's crypt... Malrec opened something below.",
            "questHooks": "Points the party toward the crypt after the pilgrim ambush.",
            "linkedEntityId": "brother_tomas_entity"
          },
          {
            "id": "father_alden_camp",
            "name": "Father Alden",
            "role": "priest",
            "personality": "Relieved, grateful, and exhausted.",
            "publicDescription": "A priest tending the camp's quiet fire.",
            "privateNotes": "He can finally admit the road is safe again.",
            "dialoguePrompt": "The faithful road is safe again. Saint Aric remembers your courage.",
            "questHooks": "Can close out the pilgrimage story and point toward camp services.",
            "linkedEntityId": "father_alden_camp_entity"
          },
          {
            "id": "camp_merchant",
            "name": "Camp Merchant",
            "role": "merchant",
            "personality": "Practical, tireless, and grateful for business.",
            "publicDescription": "A camp vendor keeping the recovery supplies organized.",
            "privateNotes": "Sells healing and revival supplies between sessions.",
            "dialoguePrompt": "Need supplies for the road ahead?",
            "questHooks": "Can stock the camp merchant shop after the campaign ends.",
            "linkedEntityId": "camp_merchant_entity"
          },
          {
            "id": "brother_malrec",
            "name": "Brother Malrec",
            "role": "boss necromancer",
            "personality": "Cold, devout, and corrupted by grief.",
            "publicDescription": "A black-robed cleric with a shattered holy symbol.",
            "privateNotes": "Summons the dead and opens the crypt.",
            "dialoguePrompt": "Your faith ends here. Kneel and join the choir beneath the stones.",
            "questHooks": "Final boss encounter for The Missing Pilgrims.",
            "linkedEntityId": "brother_malrec_entity"
          }
